# --- Features ---
msgid "Features"
msgstr "Возможности"

msgid "Everything You Need to"
msgstr "Всё, что нужно для"

msgid "Master Russian"
msgstr "изучения русского"

msgid "A complete learning ecosystem for real progress"
msgstr "Полная экосистема обучения для реального прогресса"

msgid "Alphabet & Pronunciation"
msgstr "Алфавит и произношение"

msgid "Learn the Cyrillic alphabet with pronunciation rules and audio examples for each letter."
msgstr "Изучите кириллицу с правилами произношения и аудиопримерами для каждой буквы."

msgid "Audio Lessons"
msgstr "Аудио уроки"

msgid "Improve listening and pronunciation with native speaker recordings."
msgstr "Улучшайте аудирование и произношение с записями носителей языка."

msgid "Smart Vocabulary"
msgstr "Умный словарь"

msgid "Learn Russian words with Uzbek translation, examples and pronunciation using spaced repetition."
msgstr "Учите русские слова с узбекским переводом, примерами и произношением по методу интервального повторения."

msgid "Grammar Exercises"
msgstr "Упражнения по грамматике"

msgid "Gender, cases, verb conjugation — with explanations and instant-check exercises."
msgstr "Род, падежи, спряжение глаголов — с объяснениями и мгновенной проверкой."

msgid "Gamification"
msgstr "Геймификация"

msgid "XP points, levels, achievements, streaks and leaderboard to keep learning fun."
msgstr "XP очки, уровни, достижения, серии и рейтинг — делайте обучение интересным."

msgid "Professional PDF certificates with QR verification upon completing any course."
msgstr "Профессиональные PDF-сертификаты с QR-верификацией после завершения любого курса."

