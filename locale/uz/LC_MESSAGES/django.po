# --- Features ---
msgid "Features"
msgstr "Imkoniyatlar"

msgid "Everything You Need to"
msgstr "Rus tilini o'rganish uchun"

msgid "Master Russian"
msgstr "barcha vositalar"

msgid "A complete learning ecosystem for real progress"
msgstr "Haqiqiy natijaga yo'naltirilgan to'liq ta'lim ekotizimi"

msgid "Alphabet & Pronunciation"
msgstr "Alifbo va talaffuz"

msgid "Learn the Cyrillic alphabet with pronunciation rules and audio examples for each letter."
msgstr "Kirill alifbosini o'rganing, har bir harf uchun talaffuz qoidalari va audio namunalar bilan."

msgid "Audio Lessons"
msgstr "Audio darslar"

msgid "Improve listening and pronunciation with native speaker recordings."
msgstr "Ona tili so'zlovchilari tomonidan yozilgan audio bilan tinglash va talaffuzni rivojlantiring."

msgid "Smart Vocabulary"
msgstr "So'z kartochkalari"

msgid "Learn Russian words with Uzbek translation, examples and pronunciation using spaced repetition."
msgstr "Intervalli takrorlash tizimi bilan rus so'zlarini o'zbek tarjimasida, misollar va talaffuz bilan o'rganing."

msgid "Grammar Exercises"
msgstr "Grammatika mashqlari"

msgid "Gender, cases, verb conjugation — with explanations and instant-check exercises."
msgstr "Rod, kelishiklar, fe'l tuslanishi — tushuntirish va darhol tekshirib ko'riladigan mashqlar bilan."

msgid "Gamification"
msgstr "O'yin elementlari"

msgid "XP points, levels, achievements, streaks and leaderboard to keep learning fun."
msgstr "XP ball, darajalar, yutuqlar, kunlik seriya va liderlar jadvali — o'rganishni qiziqarli qiling."

msgid "Professional PDF certificates with QR verification upon completing any course."
msgstr "Har bir kursni yakunlaganingizda QR-kod bilan tasdiqlangan rasmiy PDF sertifikat oling."

